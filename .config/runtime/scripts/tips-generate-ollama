#!/usr/bin/env sh
set -e

# Ollama-based tip generator for zsh-tips.zsh
# Contract: takes directory path as $1, outputs tips to stdout (one per line)

. "${0%/*}/../core/lib.sh"

_dir="${1:-.}"
_model="${ZSH_TIPS_DYNAMIC_MODEL:-${OLLAMA_MODEL_FLASH:-${OLLAMA_MODEL:-qwen2.5-coder:7b}}}"
_host="${OLLAMA_HOST:-127.0.0.1:11434}"

require_cmd project-context || exit 1
require_cmd is-project-dir || exit 1
require_cmd curl || exit 1
require_cmd jq || exit 1

is-project-dir "$_dir" || exit 1

ctx=$(project-context "$_dir")
[ -n "$ctx" ] || exit 1

prompt="Generate 8-12 short practical terminal tips for this project context. One tip per line, no numbering, no bullets, no prefix. Keep each under 100 chars. No generic filler.

$ctx"

payload=$(jq -n --arg m "$_model" --arg p "$prompt" '{model:$m,prompt:$p,stream:false}')

raw=$(curl -sf "http://$_host/api/generate" -d "$payload") || exit 1

printf '%s\n' "$raw" | jq -r '.response'

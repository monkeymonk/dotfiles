#!/usr/bin/env sh

set -eu

recent_file=$(ls -lt | awk 'NR==2 {print $NF}')
[ -n "${recent_file-}" ] || exit 0

if [ -n "${CLI_OPEN_CMD-}" ] && command -v "$CLI_OPEN_CMD" >/dev/null 2>&1; then
    "$CLI_OPEN_CMD" "$recent_file"
    exit 0
fi

if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$recent_file"
    exit 0
fi

if command -v open >/dev/null 2>&1; then
    open "$recent_file"
    exit 0
fi

exit 1
